    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "#if defined(UNITY_STEREO_INSTANCING_ENABLED) || defined(UNITY_SINGLE_PASS_STEREO) || defined(UNITY_STEREO_MULTIVIEW_ENABLED)\nOut = unity_StereoEyeIndex == 0 ? LeftColor : RightColor;\n#else\nOut = LeftColor;\n#endif"
}

